{
  "name": "electron-base-project",
  "version": "1.0.0",
  "description": "A base Electron starter with React and shadcn",
  "packageManager": "pnpm@10.28.0",
  "license": "MIT",
  "main": "./out/main/index.js",
  "scripts": {
    "format": "prettier --write .",
    "lint": "eslint . --ext .js,.jsx,.cjs,.mjs,.ts,.tsx,.cts,.mts --fix",
    "typecheck:node": "tsc --noEmit -p tsconfig.node.json --composite false",
    "typecheck:web": "tsc --noEmit -p tsconfig.web.json --composite false",
    "typecheck": "pnpm run typecheck:node && pnpm run typecheck:web",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio",
    "start": "electron-vite preview",
    "dev": "electron-vite dev",
    "dev:linux:safe": "ELECTRON_DISABLE_VSYNC=1 ELECTRON_OZONE_PLATFORM_HINT=auto electron-vite dev",
    "dev:linux:software": "ELECTRON_DISABLE_VSYNC=1 ELECTRON_USE_SWIFTSHADER=1 electron-vite dev",
    "dev:linux:no-ibus": "GTK_IM_MODULE=xim ELECTRON_DISABLE_VSYNC=1 electron-vite dev",
    "build": "pnpm run typecheck && electron-vite build",
    "postinstall": "node -e \"process.exit(process.env.CI ? 0 : 1)\" || electron-builder install-app-deps",
    "rebuild": "electron-rebuild -f -w better-sqlite3",
    "build:win": "pnpm run build && electron-builder --win --config --publish never",
    "build:mac": "electron-vite build && electron-builder --mac --config --publish never",
    "build:linux": "electron-vite build && electron-builder --linux --config --publish never",
    "build:linux:ci": "electron-vite build && electron-builder --linux AppImage deb --config --publish never"
  },
  "dependencies": {
    "@electron-toolkit/preload": "^3.0.0",
    "@electron-toolkit/utils": "^4.0.0",
    "@hookform/resolvers": "^5.2.2",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@tanstack/react-query": "^5.76.2",
    "axios": "^1.9.0",
    "better-sqlite3": "^12.8.0",
    "bindings": "^1.5.0",
    "class-variance-authority": "^0.7.1",
    "drizzle-orm": "^1.0.0-beta.18",
    "file-uri-to-path": "^2.0.0",
    "lucide-react": "^0.511.0",
    "prebuild-install": "^7.1.3",
    "react-hook-form": "^7.56.4",
    "zod": "^3.24.4",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@electron-toolkit/eslint-config-prettier": "^2.0.0",
    "@electron-toolkit/eslint-config-ts": "^2.0.0",
    "@electron-toolkit/tsconfig": "^1.0.1",
    "@tailwindcss/postcss": "^4.0.0",
    "@tailwindcss/typography": "^0.5.10",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.0",
    "clsx": "^2.1.1",
    "drizzle-kit": "^0.31.10",
    "electron": "^40.8.0",
    "electron-builder": "^26.8.2",
    "electron-rebuild": "^3.2.13",
    "electron-vite": "^2.0.0",
    "eslint": "^9.0.0",
    "eslint-plugin-import": "^2.31.0",
    "eslint-plugin-react": "^7.33.2",
    "postcss": "^8.4.32",
    "prettier": "^3.5.0",
    "tailwind-merge": "^3.0.0",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.7.0",
    "vite": "^6.0.0"
  }
}
